<%- include('partials/header') %>

<main class="main auth-main">
    <section class="auth-card">
        <div class="auth-heading">
            <p class="auth-kicker">Security</p>
            <h1>Change Password</h1>
            <p class="auth-subtitle">Update your password safely.</p>
        </div>

        <% if (flash && ((flash.error && flash.error.length) || (flash.success && flash.success.length))) { %>
            <div class="flash-stack" role="status" aria-live="polite">
                <% if (flash.error && flash.error.length) { %>
                    <% flash.error.forEach((message) => { %>
                        <article class="flash-message flash-error" role="alert" aria-live="assertive">
                            <span class="flash-icon" aria-hidden="true">!</span>
                            <p><%= message %></p>
                        </article>
                    <% }) %>
                <% } %>

                <% if (flash.success && flash.success.length) { %>
                    <% flash.success.forEach((message) => { %>
                        <article class="flash-message flash-success" role="status">
                            <span class="flash-icon" aria-hidden="true">✓</span>
                            <p><%= message %></p>
                        </article>
                    <% }) %>
                <% } %>
            </div>
        <% } %>

        <form action="/login/profile/change-password" method="POST" class="auth-form">
            <div class="form-group">
                <label for="currentPassword">Current Password</label>
                <input
                    id="currentPassword"
                    name="currentPassword"
                    type="password"
                    placeholder="Enter current password"
                    required
                >
            </div>

            <div class="form-group">
                <label for="updatedPassword">Updated Password</label>
                <input
                    id="updatedPassword"
                    name="updatedPassword"
                    type="password"
                    placeholder="Enter updated password"
                    required
                >
            </div>

            <div class="form-group">
                <label for="confirmUpdatedPassword">Confirm Updated Password</label>
                <input
                    id="confirmUpdatedPassword"
                    name="confirmUpdatedPassword"
                    type="password"
                    placeholder="Confirm updated password"
                    required
                >
            </div>

            <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
    </section>
</main>

<%- include('partials/footer') %>
