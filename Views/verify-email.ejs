<%- include('partials/header') %>

<main class="main auth-main">
    <section class="auth-card verify-card">
        <div class="auth-heading">
            <p class="auth-kicker">Email Verification</p>
            <h1>Enter your 8-digit code</h1>
            <p class="auth-subtitle">We sent a verification code to your registered email. Enter it below to verify your account.</p>
        </div>

        <%- include('partials/flash') %>

        <form action="/login/profile/verify-email-token" method="post" class="verify-form" autocomplete="one-time-code">
            <div class="form-group">
                <label for="verificationCode">8-digit verification code</label>
                <input
                    type="text"
                    id="verificationCode"
                    name="verificationCode"
                    inputmode="numeric"
                    pattern="[0-9]{8}"
                    maxlength="8"
                    minlength="8"
                    required
                    placeholder="12345678"
                >
            </div>

            <button type="submit" class="btn btn-primary">Verify Email</button>
        </form>

        <div class="verify-resend-row">
            <p class="auth-subtitle">Did not receive the code?</p>
            <form action="/login/profile/verify-email/resend" method="POST">
                <button type="submit" class="btn btn-secondary">Resend Verification Mail</button>
            </form>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
